rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Assessment dev rules (test mode): open access with a time bomb,
    // mirroring the Firebase console's "test mode" default.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 8, 7);
    }
  }
}
